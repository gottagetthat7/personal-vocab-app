export GEMINI_API_KEY=your_gemini_api_key_here
# export GOOGLE_API_KEY=your_google_api_key_here
export GEMINI_MODEL=gemini-2.5-flash

# Optional HTTP Basic Auth. If BOTH are set, every request requires a matching
# Authorization: Basic header (the browser handles the login prompt). Leave
# unset for local development — the app runs with no auth.
# Always serve over HTTPS in production; Basic Auth credentials are base64,
# not encrypted.
# export APP_USERNAME=your_username
# export APP_PASSWORD=a_long_random_password
